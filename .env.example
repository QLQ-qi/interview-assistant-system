# 应用设置
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=False

# 数据库
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/interview_db
REDIS_URL=redis://localhost:6379/0

# 腾讯会议
TENCENT_MEETING_APP_ID=your_app_id
TENCENT_MEETING_APP_SECRET=your_app_secret
TENCENT_MEETING_WEBHOOK_TOKEN=your_webhook_token
TENCENT_MEETING_WEBHOOK_ENCODING_AES_KEY=your_encoding_aes_key

# LLM设置
LLM_API_URL=http://localhost:11434
LLM_MODEL=qwen:latest
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.9
LLM_MAX_TOKENS=1000

# 向量模型
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda

# 前端URL
FRONTEND_URL=http://localhost:3000
